<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <solid android:color="@color/fin_lime_soft" />
            <stroke
                android:width="1.5dp"
                android:color="@color/fin_lime_strong" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <solid android:color="@color/fin_card" />
            <stroke
                android:width="1dp"
                android:color="@color/fin_border" />
        </shape>
    </item>
</selector>
