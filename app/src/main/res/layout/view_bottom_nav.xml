<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_nav"
    android:orientation="horizontal"
    android:paddingHorizontal="10dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:id="@+id/navHome"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingVertical="8dp">

        <ImageView
            android:id="@+id/navHomeIcon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="Home"
            android:src="@drawable/ic_home" />

        <TextView
            android:id="@+id/navHomeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Home"
            android:textColor="@color/fin_text_secondary"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navPortfolio"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingVertical="8dp">

        <ImageView
            android:id="@+id/navPortfolioIcon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="Portfolio"
            android:src="@drawable/ic_portfolio" />

        <TextView
            android:id="@+id/navPortfolioLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Portfolio"
            android:textColor="@color/fin_text_secondary"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navRisk"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingVertical="8dp">

        <ImageView
            android:id="@+id/navRiskIcon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="Risk"
            android:src="@drawable/ic_risk" />

        <TextView
            android:id="@+id/navRiskLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Risk"
            android:textColor="@color/fin_text_secondary"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navAnalysis"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingVertical="8dp">

        <ImageView
            android:id="@+id/navAnalysisIcon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="Analysis"
            android:src="@drawable/ic_analysis" />

        <TextView
            android:id="@+id/navAnalysisLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Analysis"
            android:textColor="@color/fin_text_secondary"
            android:textSize="11sp" />
    </LinearLayout>

</LinearLayout>
