<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/portfolioRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Summary card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_card_elevated"
        android:orientation="vertical"
        android:padding="22dp">

        <TextView
            android:id="@+id/portfolioTitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Portfolio"
            android:textColor="@color/fin_text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/portfolioSummaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="0 assets • $0.00"
            android:textColor="@color/fin_text_secondary"
            android:textSize="15sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/emptyPortfolioText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_card_glass"
        android:gravity="center"
        android:padding="28dp"
        android:text="No assets yet.\nAdd your first asset from the dashboard."
        android:textColor="@color/fin_text_secondary"
        android:textSize="15sp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/assetsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="18dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <Button
        android:id="@+id/backButton"
        style="@style/Widget.FinPilot.Button.Secondary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Back" />

</LinearLayout>
