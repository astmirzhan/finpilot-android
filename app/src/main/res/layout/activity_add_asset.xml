<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/addAssetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:letterSpacing="0.16"
            android:text="NEW POSITION"
            android:textColor="@color/fin_lime_dark"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Add Asset"
            android:textColor="@color/fin_text_primary"
            android:textSize="30sp"
            android:textStyle="bold" />

        <!-- Form card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Asset name"
                android:textColor="@color/fin_text_secondary"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/assetNameInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:hint="e.g. Apple Inc."
                android:inputType="text"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp"
                android:textColor="@color/fin_text_primary"
                android:textColorHint="@color/fin_text_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Category"
                android:textColor="@color/fin_text_secondary"
                android:textSize="13sp" />

            <Spinner
                android:id="@+id/categorySpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:paddingHorizontal="12dp"
                android:paddingVertical="12dp"
                android:popupBackground="@color/fin_card" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Amount (USD)"
                android:textColor="@color/fin_text_secondary"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/amountInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:hint="0.00"
                android:inputType="numberDecimal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp"
                android:textColor="@color/fin_text_primary"
                android:textColorHint="@color/fin_text_secondary" />
        </LinearLayout>

        <!-- Risk card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/riskLevelText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Risk level: 5/10"
                android:textColor="@color/fin_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/riskSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:max="9"
                android:progress="4"
                android:progressTint="@color/fin_lime_strong"
                android:thumbTint="@color/fin_lime_strong" />

            <CheckBox
                android:id="@+id/longTermCheckBox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:buttonTint="@color/fin_lime_strong"
                android:text="Long-term asset"
                android:textColor="@color/fin_text_primary" />
        </LinearLayout>

        <Button
            android:id="@+id/saveAssetButton"
            style="@style/Widget.FinPilot.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Save Asset" />

        <Button
            android:id="@+id/cancelButton"
            style="@style/Widget.FinPilot.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Cancel" />

    </LinearLayout>
</ScrollView>
